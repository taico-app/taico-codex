{
  "compilerOptions": {
    // Syntax
    "lib": [
      "ES2022",
      "DOM"
    ],
    "target": "ES2022",
    // Module
    "module": "ES2022",
    "moduleResolution": "Bundler",
    // Type Checking
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    // Base URL
    "baseUrl": ".",
    // Alias
    "paths": {
      "@taico/client": [
        "packages/client/src/v1/index.ts"
      ],
      "@taico/client/v2": [
        "packages/client/src/v2/index.ts"
      ],
      "@taico/shared": [
        "packages/shared/src/index.ts"
      ],
      "@taico/events": [
        "packages/events/src/index.ts"
      ],
      "@taico/errors": [
        "packages/errors/src/index.ts"
      ]
    }
  }
}
