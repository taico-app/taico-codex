{
  "name": "@taico/client",
  "version": "0.0.1",
  "type": "module",
  "private": false,
  "license": "MIT",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist",
    "package.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./contracts": {
      "types": "./dist/contracts/types.d.ts",
      "import": "./dist/contracts/types.js",
      "default": "./dist/contracts/types.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:prod": "npm run copy:contracts && npm run generate:types && npm run generate:client && npm run build",
    "dev": "tsc -w -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.build.json",
    "lint": "echo \"(shared) lint todo\"",
    "copy:contracts": "mkdir -p contracts && cp ../../apps/backend/openapi.json contracts/openapi.json",
    "generate:types": "openapi-typescript contracts/openapi.json -o contracts/types.ts",
    "generate:client": "openapi --input contracts/openapi.json --output src/client --client fetch && npm run fix:esm-imports",
    "fix:esm-imports": "node scripts/fix-esm-imports.js",
    "pack": "npm run build:prod && npm pack",
    "release": "npm run build:prod && npm publish --access public"
  },
  "devDependencies": {
    "openapi-typescript": "^7.10.1",
    "openapi-typescript-codegen": "^0.29.0",
    "typescript": "^5.6.3"
  }
}
