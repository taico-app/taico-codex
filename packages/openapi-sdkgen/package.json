{
  "name": "@taico/openapi-sdkgen",
  "version": "0.2.12",
  "type": "module",
  "private": false,
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "openapi-sdkgen": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test:api": "tsx --tsconfig test/api/tsconfig.json test/api/src/main.ts",
    "test:client": "tsx test/client/test-sdk.ts",
    "generate:spec": "tsx --tsconfig test/api/tsconfig.json test/api/src/main.ts --generate-spec",
    "clean": "rm -rf test/client/generated",
    "generate": "tsx src/cli.ts test/api/openapi.json test/client/generated",
    "lint:generated": "tsc --noEmit --project test/client/tsconfig.json",
    "test": "npm run clean && npm run generate:spec && npm run generate && npm run lint:generated && node test/run.mjs",
    "pack": "npm run build && npm pack",
    "release": "npm run build && npm publish --access public"
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/swagger": "^11.2.6",
    "@types/node": "^20.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "tsx": "^4.7.0",
    "typescript": "^5.6.3"
  }
}
