# Create one like this for each agent.
AGENT_SLUG="claude" # Which agent this worker represents.
BASE_URL="http://localhost:2000" # This is the url where your backend is running.
ACCESS_TOKEN="create via $BASE_URL/agents/agent/$AGENT_SLUG" # Create token with at least task:*, meta:*, context:*, agents:read, mcp:use scopes.
WORK_DIR="/Users/franciscogalarza/tmp" # A folder where work will happen. Needs to be absolute path.