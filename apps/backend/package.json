{
  "name": "@taico/taico",
  "version": "0.2.0",
  "private": false,
  "license": "MIT",
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "bin": {
    "taico": "./dist/main.js"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "exports": {
    ".": {
      "main": "./dist/main.js",
      "types": "./dist/main.d.ts",
      "default": "./dist/main.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "nest build",
    "build:prod": "npm run build && NODE_ENV=development node dist/main.js --generate-openapi",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch -- --server",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:should-be-e2e": "jest --config ./test/jest-e2e.json --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json tasks.e2e-spec.ts",
    "test:e2e:worker-auth": "jest --config ./test/jest-e2e.json worker-auth.e2e-spec.ts --runInBand",
    "dev": "npm run start:dev",
    "typecheck": "tsc --noEmit",
    "does-it-start": "(nest start & ) && sleep 10 && kill $! || true",
    "init-test-user": "npm run build && node dist/scripts/init-test-user.js",
    "create-admin": "npm run build && node dist/scripts/create-admin-user.js",
    "pack": "npm pack",
    "release": "npm publish --access public"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.76",
    "@google/adk": "^0.2.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/platform-socket.io": "^11.1.17",
    "@nestjs/schedule": "^5.0.1",
    "@nestjs/swagger": "^11.2.1",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.17",
    "@openai/agents": "^0.5.2",
    "@opencode-ai/sdk": "^1.1.28",
    "@taico/adk-session-store": "^0.1.0",
    "@taico/errors": "^0.2.8",
    "@taico/events": "^0.2.8",
    "@taico/shared": "^0.2.8",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie": "^0.7.2",
    "cookie-parser": "^1.4.7",
    "cron-parser": "^5.5.0",
    "fuse.js": "^7.1.0",
    "jszip": "^3.10.1",
    "ollama": "^0.6.3",
    "openai": "^6.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.3",
    "sqlite3": "^5.1.7",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.27"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/cookie": "^0.6.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.1",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.8",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
