# Frontend Port (Vite development server)
UI_PORT=2011
LEGACY_UI_PORT=2012

# Backend Port (NestJS application)
BACKEND_PORT=2013

# Vite (UI) acts as the entry point gateway, so the issuer should be that address
ISSUER_URL=http://localhost:2011

# Database Configuration
DATABASE_PATH=data/database-4.sqlite

# Node Environment
# NODE_ENV=production

# JWKS Configuration
# Time-to-live for JWKS keys signing in hours (default: 72 hours / 3 days)
# After this period, the key will not be used for signing new tokens
JWKS_KEY_SIGNING_TTL_HOURS=72

# Time-to-live for JWKS keys verification in hours (default: 1440 hours / 60 days)
# After this period, the key will not be used for verifying tokens
# This should be longer than signing TTL to allow old tokens to be verified
JWKS_KEY_VERIFYING_TTL_HOURS=1440
