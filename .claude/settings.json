{
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "tasks",
    "claude-tasks"
  ],
  "permissions": {
    "allow": [
      "SlashCommand",
      "Bash",
      "Read",
      "Write",
      "Edit",
      "mcp__tasks__*",
      "mcp__context__*"
    ],
    "deny": [],
    "ask": []
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/hooks/stop-comment.sh $(jq -r '.transcript_path')"
          }
        ]
      }
    ]
  }
}